<view class="page {{entered ? 'entered' : ''}} {{isWide ? 'is-wide' : ''}} {{isPc ? 'is-pc' : ''}}">
  <view class="nav" style="padding-top: {{statusBarHeight}}px;" bindtap="dismissKeyboard">
    <view class="nav-inner" catchtap="noop">
      <view class="menu-btn" bindtap="openDrawer">
        <view class="menu-line"></view>
        <view class="menu-line"></view>
        <view class="menu-line"></view>
      </view>
      <view class="nav-center">
        <view class="nav-title">{{navTitle}}</view>
        <view class="nav-sub">{{navSub}}</view>
      </view>
      <view class="nav-right" bindtap="onNewChat">新对话</view>
    </view>
  </view>

  <scroll-view
    class="msgs"
    scroll-y
    scroll-with-animation
    scroll-into-view="{{scrollInto}}"
    enhanced
    show-scrollbar="{{false}}"
    bindtap="dismissKeyboard"
  >
    <view class="msgs-pad">
      <view wx:if="{{messages.length === 0}}" class="welcome">
        <image class="welcome-avatar" src="/assets/daidai-avatar.png" mode="aspectFill" />
        <view class="welcome-hi">{{welcomeHi}}</view>
        <view class="welcome-sub">{{welcomeSub}}</view>
        <view wx:if="{{!loggedIn}}" class="guest-tip" bindtap="openLogin">
          当前是游客模式 · 登录后即可使用
        </view>

        <view class="sec-head">
          <text class="sec-title">快捷能力</text>
        </view>
        <view class="skill-grid">
          <view
            class="skill-chip {{activeSkill === item.id ? 'on' : ''}}"
            wx:for="{{skills}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="onSkill"
          >
            <text class="skill-chip-emoji">{{item.emoji}}</text>
            <text class="skill-chip-name">{{item.name}}</text>
          </view>
        </view>

        <view class="sec-head">
          <text class="sec-title">角色面具</text>
          <text class="sec-link" bindtap="openMaskPanel">全部 · 自定义</text>
        </view>
        <scroll-view class="mask-scroll" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="mask-row">
            <view class="mask-card create" bindtap="openMaskCreate">
              <view class="mask-emoji">＋</view>
              <view class="mask-name">创建面具</view>
            </view>
            <view
              class="mask-card {{activeMask === item.id ? 'on' : ''}}"
              wx:for="{{maskPreview}}"
              wx:key="id"
              data-id="{{item.id}}"
              bindtap="onPickMask"
            >
              <view class="mask-emoji">{{item.emoji}}</view>
              <view class="mask-name">{{item.name}}</view>
              <view class="mask-desc">{{item.desc}}</view>
            </view>
          </view>
        </scroll-view>
      </view>

      <block wx:for="{{messages}}" wx:key="id">
        <view class="row {{item.role === 'user' ? 'mine' : 'ai'}}" id="m-{{item.id}}">
          <image
            wx:if="{{item.role !== 'user'}}"
            class="avatar"
            src="/assets/daidai-avatar.png"
            mode="aspectFill"
          />
          <view class="bubble-wrap">
            <view
              class="bubble {{item.role}}"
              data-id="{{item.id}}"
              bindlongpress="onMsgLongPress"
              bindtap="onMsgTap"
            >
              <view wx:if="{{item.quote}}" class="quote-chip in-bubble">
                <text class="quote-chip-who">{{item.quote.who}}</text>
                <text class="quote-chip-text">{{item.quote.preview}}</text>
              </view>
              <text wx:if="{{item.content}}" class="bubble-text" user-select>{{item.content}}</text>
              <view wx:if="{{item.imageConfirm}}" class="bubble-actions" catchtap="noop">
                <view
                  class="action-btn primary"
                  data-id="{{item.id}}"
                  catchtap="onConfirmImageGen"
                >生成图片</view>
                <view
                  class="action-btn"
                  data-id="{{item.id}}"
                  catchtap="onCancelImageGen"
                >取消</view>
              </view>
              <view wx:if="{{item.imageEditConfirm}}" class="bubble-actions" catchtap="noop">
                <view
                  class="action-btn primary"
                  data-id="{{item.id}}"
                  catchtap="onConfirmImageEdit"
                >确认改图</view>
                <view
                  class="action-btn"
                  data-id="{{item.id}}"
                  catchtap="onCancelImageEdit"
                >取消</view>
              </view>
              <image
                wx:if="{{item.image}}"
                class="bubble-img"
                src="{{item.image}}"
                mode="widthFix"
                show-menu-by-longpress="{{false}}"
                catchtap="previewImage"
                data-src="{{item.image}}"
              />
              <view wx:if="{{item.loading}}" class="typing">
                <view class="dot"></view>
                <view class="dot"></view>
                <view class="dot"></view>
              </view>
            </view>
          </view>
        </view>
      </block>
      <view id="m-bottom" class="bottom-anchor"></view>
    </view>
  </scroll-view>

  <view class="img-bar" wx:if="{{activeSkill === 'image' || activeSkill === 'edit'}}">
    <text class="img-bar-label">画幅</text>
    <view
      class="ratio {{imageSize === item.value ? 'on' : ''}}"
      wx:for="{{sizes}}"
      wx:key="value"
      data-value="{{item.value}}"
      bindtap="onSize"
    >{{item.label}}</view>
  </view>

  <view
    class="composer {{activeSkill === 'edit' ? 'edit-mode' : ''}}"
    catchtap="noop"
  >
    <view class="quote-bar" wx:if="{{quoteMsg}}">
      <view class="quote-bar-main">
        <text class="quote-bar-label">{{quoteMode === 'reply' ? '回复' : '引用'}}</text>
        <text class="quote-bar-who">{{quoteMsg.who}}</text>
        <text class="quote-bar-text">{{quoteMsg.preview}}</text>
      </view>
      <view class="quote-bar-x" bindtap="clearQuote">×</view>
    </view>
    <view class="edit-bar" wx:if="{{editingMsgId}}">
      <text class="edit-bar-label">修改消息</text>
      <view class="edit-bar-x" bindtap="clearEditing">取消</view>
    </view>
    <view class="tag-row" wx:if="{{(activeSkill && activeSkill !== 'edit') || activeMask}}">
      <view class="skill-tag" wx:if="{{activeSkill && activeSkill !== 'edit'}}" bindtap="clearSkill">
        <text>{{skillLabel}}</text>
        <text class="skill-x">×</text>
      </view>
      <view class="skill-tag mask" wx:if="{{activeMask}}" bindtap="clearMask">
        <text>{{maskLabel}}</text>
        <text class="skill-x">×</text>
      </view>
    </view>
    <view class="composer-box {{inputFocus ? 'focus' : ''}}">
      <view class="plus-wrap">
        <view
          wx:if="{{activeSkill === 'edit'}}"
          class="edit-exit"
          bindtap="clearSkill"
        >退出</view>
        <view
          wx:if="{{activeSkill === 'edit'}}"
          class="plus upload {{editImagePath ? 'has-img' : ''}}"
          bindtap="pickEditImage"
        >
          <image
            wx:if="{{editImagePath}}"
            class="plus-thumb"
            src="{{editImagePath}}"
            mode="aspectFill"
          />
          <text wx:else class="plus-upload-ico">⬆</text>
        </view>
        <view
          wx:if="{{activeSkill === 'edit' && editImagePath}}"
          class="edit-clear"
          catchtap="clearEditImage"
        >换图</view>
        <view wx:else class="plus" bindtap="onPlus">＋</view>
      </view>
      <textarea
        class="input"
        value="{{input}}"
        placeholder="{{placeholder}}"
        placeholder-class="input-ph"
        confirm-type="send"
        confirm-hold="{{false}}"
        adjust-position="{{true}}"
        cursor-spacing="28"
        auto-height
        maxlength="2000"
        show-confirm-bar="{{false}}"
        disable-default-padding
        bindinput="onInput"
        bindconfirm="onSend"
        bindfocus="onInputFocus"
        bindblur="onInputBlur"
        disabled="{{busy}}"
      />
      <view class="send {{canSend ? 'on' : ''}}" bindtap="onSend">
        {{activeSkill === 'image' ? '生成' : activeSkill === 'edit' ? '改图' : '发送'}}
      </view>
    </view>
    <view class="safe"></view>
  </view>

  <!-- 加号面板 -->
  <view class="sheet-mask" wx:if="{{showSheet}}" bindtap="closeSheet"></view>
  <view class="sheet {{showSheet ? 'show' : ''}}">
    <view class="sheet-title">添加能力</view>
    <view class="sheet-grid">
      <view class="sheet-item" bindtap="openMaskPanel">
        <view class="sheet-ico" style="background: rgba(236,72,153,0.12);">🎭</view>
        <text class="sheet-name">角色面具</text>
      </view>
      <view class="sheet-item" bindtap="pickEditImage">
        <view class="sheet-ico" style="background: rgba(244,63,94,0.12);">📷</view>
        <text class="sheet-name">上传改图</text>
      </view>
      <view
        class="sheet-item"
        wx:for="{{skills}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onSkillFromSheet"
      >
        <view class="sheet-ico" style="background: {{item.bg}};">{{item.emoji}}</view>
        <text class="sheet-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 面具面板 -->
  <view class="sheet-mask" wx:if="{{showMaskPanel}}" bindtap="closeMaskPanel"></view>
  <view class="panel {{showMaskPanel ? 'show' : ''}}">
    <view class="panel-head">
      <view class="panel-title">角色面具</view>
      <view class="panel-action" bindtap="openMaskCreate">＋ 创建</view>
    </view>
    <scroll-view scroll-y class="panel-body" enhanced show-scrollbar="{{false}}">
      <view class="panel-sec" wx:if="{{customMasks.length}}">我的面具</view>
      <view class="panel-grid" wx:if="{{customMasks.length}}">
        <view
          class="panel-card {{activeMask === item.id ? 'on' : ''}}"
          wx:for="{{customMasks}}"
          wx:key="id"
        >
          <view class="panel-card-main" data-id="{{item.id}}" bindtap="onPickMask">
            <view class="panel-emoji">{{item.emoji}}</view>
            <view class="panel-name">{{item.name}}</view>
            <view class="panel-desc">{{item.desc}}</view>
          </view>
          <view class="panel-del" data-id="{{item.id}}" catchtap="onDeleteMask">删除</view>
        </view>
      </view>
      <view class="panel-sec">内置面具</view>
      <view class="panel-grid">
        <view
          class="panel-card {{activeMask === item.id ? 'on' : ''}}"
          wx:for="{{builtinMasks}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onPickMask"
        >
          <view class="panel-emoji">{{item.emoji}}</view>
          <view class="panel-name">{{item.name}}</view>
          <view class="panel-desc">{{item.desc}}</view>
        </view>
      </view>
      <view class="panel-safe"></view>
    </scroll-view>
  </view>

  <!-- 创建面具 -->
  <view class="sheet-mask" wx:if="{{showMaskCreate}}" bindtap="closeMaskCreate"></view>
  <view class="panel create-panel {{showMaskCreate ? 'show' : ''}}">
    <view class="panel-head">
      <view class="panel-title">创建自定义面具</view>
      <view class="panel-action dim" bindtap="closeMaskCreate">取消</view>
    </view>
    <scroll-view scroll-y class="panel-body form" enhanced show-scrollbar="{{false}}">
      <view class="form-label">头像</view>
      <view class="emoji-row">
        <view
          class="emoji-pick {{form.emoji === item ? 'on' : ''}}"
          wx:for="{{emojiPresets}}"
          wx:key="*this"
          data-emoji="{{item}}"
          bindtap="onPickEmoji"
        >{{item}}</view>
      </view>
      <view class="form-label">名称</view>
      <input class="form-input" value="{{form.name}}" placeholder="例如：毒舌吐槽役" bindinput="onFormName" />
      <view class="form-label">一句话简介</view>
      <input class="form-input" value="{{form.desc}}" placeholder="别人一眼看懂它能干什么" bindinput="onFormDesc" />
      <view class="form-label">人设 / 系统提示词</view>
      <textarea
        class="form-area"
        value="{{form.prompt}}"
        placeholder="描述性格、口吻、擅长做什么、不要做什么…"
        maxlength="1000"
        bindinput="onFormPrompt"
      />
      <view class="form-label">开场白（可选）</view>
      <textarea
        class="form-area short"
        value="{{form.hello}}"
        placeholder="戴上面具后的第一句话"
        maxlength="200"
        bindinput="onFormHello"
      />
      <view class="form-save" bindtap="onSaveMask">保存并使用</view>
      <view class="panel-safe"></view>
    </scroll-view>
  </view>

  <!-- 左侧抽屉 -->
  <view class="drawer-mask {{showDrawer ? 'show' : ''}}" bindtap="closeDrawer"></view>
  <view class="drawer {{showDrawer ? 'show' : ''}}" style="padding-top: {{statusBarHeight}}px;">
    <view class="drawer-user {{isMember ? 'vip' : ''}}" bindtap="onOpenProfile">
      <view class="drawer-avatar-wrap {{isMember ? 'vip' : ''}}">
        <image
          wx:if="{{loggedIn}}"
          class="drawer-avatar"
          src="{{user.avatarUrl || '/assets/daidai-avatar.png'}}"
          mode="aspectFill"
        />
        <view wx:else class="drawer-avatar ph">游</view>
        <view wx:if="{{isMember}}" class="avatar-crown">👑</view>
      </view>
      <view class="drawer-user-meta">
        <view class="drawer-name-row">
          <view class="drawer-name">{{loggedIn ? user.nickName : '游客'}}</view>
          <view wx:if="{{loggedIn}}" class="member-pill {{isMember ? 'vip' : ''}}">
            {{isMember ? '会员' : '普通'}}
          </view>
        </view>
        <view class="drawer-tip">{{loggedIn ? (isMember ? '尊享会员 · 生图不限次数' : '已登录 · 呆呆 AI') : '游客模式 · 使用需登录'}}</view>
      </view>
      <view class="drawer-user-arrow">›</view>
    </view>

    <view class="drawer-item" bindtap="onNewChatFromDrawer">＋ 新对话</view>
    <view class="drawer-item" bindtap="goHome">⌂ 返回首页</view>

    <view class="drawer-sec">最近对话</view>
    <scroll-view scroll-y class="drawer-hist" enhanced show-scrollbar="{{false}}">
      <view wx:if="{{!loggedIn}}" class="drawer-empty">登录后可查看历史对话</view>
      <view wx:elif="{{!historyList.length}}" class="drawer-empty">暂无历史，聊几句就会出现在这里</view>
      <block wx:else>
        <view
          class="drawer-hist-item {{sessionId === item.id ? 'on' : ''}}"
          wx:for="{{historyList}}"
          wx:key="id"
        >
          <view class="drawer-hist-main" data-id="{{item.id}}" bindtap="onPickHistory">
            <view class="drawer-hist-title">{{item.title}}</view>
            <view class="drawer-hist-preview">{{item.preview}}</view>
          </view>
          <view class="drawer-hist-del" data-id="{{item.id}}" catchtap="onDeleteHistory">删</view>
        </view>
      </block>
    </scroll-view>

    <view class="drawer-foot">
      <view wx:if="{{!loggedIn}}" class="drawer-item primary" bindtap="openLogin">登录以使用</view>
      <view wx:else class="drawer-item danger" bindtap="onLogout">退出登录</view>
    </view>
  </view>

  <!-- 个人资料卡：普通 / 会员 -->
  <view class="profile-mask {{showProfile ? 'show' : ''}}" bindtap="closeProfile"></view>
  <view class="profile-card {{showProfile ? 'show' : ''}} {{isMember ? 'vip' : ''}}" catchtap="noop">
    <view class="profile-banner {{isMember ? 'vip' : ''}}">
      <view class="profile-banner-glow"></view>
      <view class="profile-close" bindtap="closeProfile">✕</view>
      <view class="profile-avatar-wrap {{isMember ? 'vip' : ''}}">
        <image
          class="profile-avatar"
          src="{{(profile && profile.avatarUrl) || user.avatarUrl || '/assets/daidai-avatar.png'}}"
          mode="aspectFill"
        />
        <view wx:if="{{isMember}}" class="profile-crown">👑</view>
      </view>
      <view class="profile-name">{{(profile && profile.nickName) || user.nickName}}</view>
      <view class="profile-badge {{isMember ? 'vip' : ''}}">
        {{isMember ? '✦ 尊享会员 ✦' : '普通用户'}}
      </view>
      <view wx:if="{{profile && profile.account}}" class="profile-account">{{profile.account}}</view>
    </view>

    <view class="profile-body">
      <view wx:if="{{profileLoading}}" class="profile-loading">加载中…</view>
      <block wx:else>
        <view class="profile-stats">
          <view class="profile-stat">
            <view class="profile-stat-num {{isMember ? 'vip' : ''}}">
              {{isMember ? '∞' : (profile ? profile.quotaText : '—')}}
            </view>
            <view class="profile-stat-label">今日生图额度</view>
          </view>
          <view class="profile-stat-divider"></view>
          <view class="profile-stat">
            <view class="profile-stat-num">{{profile ? profile.chatToday : '—'}}</view>
            <view class="profile-stat-label">今日对话</view>
          </view>
          <view class="profile-stat-divider"></view>
          <view class="profile-stat">
            <view class="profile-stat-num">{{profile ? profile.imageToday : '—'}}</view>
            <view class="profile-stat-label">今日出图</view>
          </view>
        </view>

        <view wx:if="{{isMember}}" class="profile-perks vip">
          <view class="perk-row"><text class="perk-ico">✨</text>生图 / 改图不限次数</view>
          <view class="perk-row"><text class="perk-ico">⚡</text>专属通道，优先响应</view>
        </view>
        <view wx:else class="profile-perks">
          <view class="perk-row muted"><text class="perk-ico">🎨</text>每天免费生图 / 改图共 2 次</view>
          <view class="perk-row muted"><text class="perk-ico">👑</text>会员可不限次数，详询管理员开通</view>
        </view>

        <view wx:if="{{memberSinceText}}" class="profile-joined">加入于 {{memberSinceText}}</view>
      </block>
    </view>
  </view>

  <!-- 登录面板：验证码登录 -->
  <view class="sheet-mask login-mask" wx:if="{{showLogin}}" bindtap="closeLogin"></view>
  <view class="login-sheet {{showLogin ? 'show' : ''}}" catchtap="noop">
    <view class="login-handle"></view>
    <view class="login-brand">呆呆网络</view>
    <view class="login-sheet-title">登录</view>
    <view class="login-sheet-desc">使用 QQ / Gmail / 网易邮箱接收验证码登录</view>

    <view class="login-fields">
      <input
        class="nick-input"
        type="text"
        placeholder="QQ / Gmail / 网易邮箱"
        value="{{loginAccount}}"
        bindinput="onAccountInput"
      />
      <view class="code-row">
        <input
          class="nick-input code-input"
          type="number"
          maxlength="6"
          placeholder="验证码"
          value="{{loginCode}}"
          bindinput="onCodeInput"
        />
        <view
          class="code-btn {{codeCooling || codeSending ? 'disabled' : ''}}"
          catchtap="onSendCode"
        >{{codeCooling ? codeLeft + 's' : (codeSending ? '发送中' : '获取验证码')}}</view>
      </view>
    </view>

    <button
      class="login-btn login-btn-sm"
      loading="{{loginLoading}}"
      hover-class="login-btn-hover"
      bindtap="onCodeLogin"
    >登录</button>

    <view class="login-cancel" bindtap="closeLogin">稍后再说</view>
  </view>
</view>

<!-- 长按消息菜单（仿微信：回复 / 引用 / 修改 / 复制） -->
<view class="msg-menu-mask" wx:if="{{showMsgMenu}}" bindtap="closeMsgMenu" catchtouchmove="noop">
  <view class="msg-menu" style="top: {{msgMenuTop}}px; left: {{msgMenuLeft}}px;" catchtap="noop">
    <view class="msg-menu-item" data-act="reply" bindtap="onMsgMenuAct">回复</view>
    <view class="msg-menu-item" data-act="quote" bindtap="onMsgMenuAct">引用</view>
    <view class="msg-menu-item" wx:if="{{msgMenuCanEdit}}" data-act="edit" bindtap="onMsgMenuAct">修改</view>
    <view class="msg-menu-item" data-act="copy" bindtap="onMsgMenuAct">复制</view>
  </view>
</view>

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f7f8fa;
  box-sizing: border-box;
}

.page .nav,
.page .msgs,
.page .composer,
.page .img-bar {
  opacity: 0;
  transform: translate3d(0, 24rpx, 0);
  transition: opacity 0.4s ease, transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.page.entered .nav,
.page.entered .msgs,
.page.entered .composer,
.page.entered .img-bar {
  opacity: 1;
  transform: translate3d(0, 0, 0);
}

.page.entered .msgs {
  transition-delay: 0.04s;
}

.page.entered .composer,
.page.entered .img-bar {
  transition-delay: 0.08s;
}

.nav {
  background: #fff;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
}

.nav-inner {
  height: 88rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
}

.menu-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.menu-line {
  width: 34rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #1d2129;
}

.back {
  width: 72rpx;
  height: 72rpx;
  line-height: 68rpx;
  text-align: center;
  font-size: 52rpx;
  color: #1d2129;
  font-weight: 300;
}

.nav-center {
  flex: 1;
  text-align: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1d2129;
}

.nav-right {
  min-width: 72rpx;
  padding: 0 8rpx;
  font-size: 26rpx;
  color: #4e5969;
  text-align: right;
}

.msgs {
  flex: 1;
  height: 0;
}

.msgs-pad {
  padding: 24rpx 28rpx 20rpx;
  min-height: 100%;
  box-sizing: border-box;
}

.welcome {
  padding: 80rpx 8rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.welcome-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #3b82f6, #60a5fa);
  color: #fff;
  font-size: 52rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(59, 130, 246, 0.25);
}

.welcome-hi {
  font-size: 44rpx;
  font-weight: 700;
  color: #1d2129;
  margin-bottom: 12rpx;
}

.welcome-sub {
  font-size: 26rpx;
  color: #86909c;
  margin-bottom: 40rpx;
}

.sec-head {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8rpx 0 16rpx;
}

.sec-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #4e5969;
}

.sec-link {
  font-size: 24rpx;
  color: #3b82f6;
}

.skill-grid {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.skill-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 8rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
}

.skill-chip.on {
  border-color: rgba(59, 130, 246, 0.45);
  background: #f0f7ff;
}

.skill-chip-emoji {
  font-size: 34rpx;
}

.skill-chip-name {
  font-size: 22rpx;
  color: #1d2129;
}

.mask-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.mask-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 2rpx 12rpx;
}

.mask-card {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
  padding: 22rpx 18rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
  box-sizing: border-box;
  vertical-align: top;
  white-space: normal;
}

.mask-card.create {
  align-items: center;
  justify-content: center;
  min-height: 168rpx;
  border: 2rpx dashed rgba(59, 130, 246, 0.35);
  background: #f8fbff;
}

.mask-card.on {
  border-color: rgba(236, 72, 153, 0.45);
  background: #fff5f9;
}

.mask-emoji {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.mask-card.create .mask-emoji {
  font-size: 44rpx;
  color: #3b82f6;
  margin-bottom: 8rpx;
}

.mask-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1d2129;
  margin-bottom: 4rpx;
}

.mask-desc {
  font-size: 20rpx;
  color: #86909c;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.nav-sub {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: #86909c;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #3b82f6, #60a5fa);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
  gap: 16rpx;
}

.row.mine {
  justify-content: flex-end;
}

.bubble-wrap {
  max-width: 78%;
  position: relative;
}

.bubble {
  padding: 22rpx 26rpx;
  border-radius: 28rpx;
  line-height: 1.65;
  font-size: 28rpx;
  word-break: break-word;
}

.bubble.ai {
  background: #fff;
  color: #1d2129;
  border-bottom-left-radius: 10rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
}

.bubble.user {
  background: #3b82f6;
  color: #fff;
  border-bottom-right-radius: 10rpx;
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.65;
  white-space: pre-wrap;
}

/* 聊天里只显示图；点开用系统相册全屏预览；水印只烙在 AI 出图 JPEG 里 */
.bubble-img {
  display: block;
  width: 480rpx;
  max-width: 100%;
  margin-top: 8rpx;
  border-radius: 16rpx;
  background: #eef1f5;
  overflow: hidden;
}

.quote-chip.in-bubble {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 12rpx 14rpx;
  margin-bottom: 10rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.06);
  border-left: 4rpx solid #94a3b8;
}

.bubble.user .quote-chip.in-bubble {
  background: rgba(255, 255, 255, 0.22);
  border-left-color: rgba(255, 255, 255, 0.7);
}

.quote-chip-who {
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
}

.bubble.user .quote-chip-who {
  color: rgba(255, 255, 255, 0.85);
}

.quote-chip-text {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.bubble.user .quote-chip-text {
  color: rgba(255, 255, 255, 0.9);
}

.quote-bar,
.edit-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 0 20rpx 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #f1f5f9;
}

.quote-bar-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.quote-bar-label,
.edit-bar-label {
  font-size: 22rpx;
  color: #3b82f6;
  font-weight: 600;
}

.quote-bar-who {
  font-size: 22rpx;
  color: #64748b;
}

.quote-bar-text {
  font-size: 24rpx;
  color: #475569;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quote-bar-x,
.edit-bar-x {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #94a3b8;
  font-size: 32rpx;
  flex-shrink: 0;
}

.edit-bar {
  justify-content: space-between;
}

.msg-menu-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1200;
  background: rgba(0, 0, 0, 0.18);
}

.msg-menu {
  position: fixed;
  min-width: 200rpx;
  padding: 8rpx 0;
  border-radius: 16rpx;
  background: #2f343b;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.28);
  z-index: 1201;
}

.msg-menu-item {
  padding: 22rpx 36rpx;
  color: #fff;
  font-size: 28rpx;
  text-align: center;
}

.msg-menu-item:active {
  background: rgba(255, 255, 255, 0.08);
}

.typing {
  display: flex;
  gap: 10rpx;
  padding: 8rpx 4rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #c9cdd4;
  animation: blink 1.2s infinite ease-in-out;
}

.dot:nth-child(2) {
  animation-delay: 0.15s;
}

.dot:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes blink {
  0%,
  80%,
  100% {
    opacity: 0.35;
  }
  40% {
    opacity: 1;
  }
}

.bottom-anchor {
  height: 8rpx;
}

.img-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 24rpx 0;
  flex-shrink: 0;
  background: #fff;
}

.img-bar-label {
  font-size: 22rpx;
  color: #86909c;
  margin-right: 4rpx;
}

.ratio {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #4e5969;
  background: #f2f3f5;
}

.ratio.on {
  color: #3b82f6;
  background: #e8f3ff;
  font-weight: 600;
}


.composer {
  background: #fff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  padding: 12rpx 20rpx 0;
  flex-shrink: 0;
}

.composer.edit-mode {
  padding-top: 52rpx;
}

.skill-tag {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin: 0 12rpx 12rpx 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #e8f3ff;
  color: #3b82f6;
  font-size: 22rpx;
}

.skill-tag.mask {
  background: #fff0f6;
  color: #ec4899;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  padding-left: 8rpx;
}

.skill-x {
  font-size: 26rpx;
  opacity: 0.7;
}

.composer-box {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  background: #f2f3f5;
  border-radius: 28rpx;
  padding: 10rpx 12rpx 10rpx 12rpx;
}

.plus-wrap {
  position: relative;
  width: 64rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.edit-exit {
  position: absolute;
  left: -8rpx;
  bottom: 76rpx;
  z-index: 2;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(29, 33, 41, 0.78);
  color: #fff;
  font-size: 20rpx;
  line-height: 1.2;
  white-space: nowrap;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.edit-clear {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #ec4899;
  line-height: 1.2;
}

.plus {
  width: 64rpx;
  height: 64rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 40rpx;
  color: #4e5969;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.plus.upload {
  background: #fff;
  border: 2rpx dashed rgba(236, 72, 153, 0.45);
  color: #ec4899;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-sizing: border-box;
}

.plus.upload.has-img {
  border-style: solid;
  border-color: rgba(236, 72, 153, 0.35);
  padding: 0;
}

.plus-upload-ico {
  font-size: 32rpx;
  line-height: 1;
  font-weight: 600;
}

.plus-thumb {
  width: 100%;
  height: 100%;
}

.input {
  flex: 1;
  height: 68rpx;
  font-size: 28rpx;
  color: #1d2129;
}

.send {
  min-width: 112rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 22rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #c9cdd4;
  background: #e5e6eb;
  flex-shrink: 0;
}

.send.on {
  color: #fff;
  background: #3b82f6;
}

.safe {
  height: calc(12rpx + env(safe-area-inset-bottom));
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 80;
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  transform: translateY(110%);
  transition: transform 0.28s ease;
}

.sheet.show {
  transform: translateY(0);
}

.sheet-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 28rpx 12rpx;
}

.sheet-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.sheet-ico {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.sheet-name {
  font-size: 22rpx;
  color: #4e5969;
}

.sheet-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d2129;
  margin-bottom: 28rpx;
}

.panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  top: 18%;
  z-index: 95;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(110%);
  transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  display: flex;
  flex-direction: column;
}

.panel.show {
  transform: translateY(0);
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1d2129;
}

.panel-action {
  font-size: 26rpx;
  color: #3b82f6;
  font-weight: 600;
}

.panel-action.dim {
  color: #86909c;
  font-weight: 400;
}

.panel-body {
  flex: 1;
  height: 0;
  padding: 0 28rpx;
  box-sizing: border-box;
}

.panel-sec {
  font-size: 24rpx;
  color: #86909c;
  margin: 12rpx 0 16rpx;
}

.panel-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.panel-card {
  background: #f7f8fa;
  border-radius: 24rpx;
  padding: 24rpx 20rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.panel-card.on {
  border-color: rgba(236, 72, 153, 0.4);
  background: #fff5f9;
}

.panel-emoji {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.panel-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d2129;
}

.panel-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #86909c;
  line-height: 1.35;
}

.panel-del {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #f53f3f;
}

.panel-safe {
  height: calc(32rpx + env(safe-area-inset-bottom));
}

.form-label {
  font-size: 24rpx;
  color: #4e5969;
  margin: 8rpx 0 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-area {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-area.short {
  min-height: 120rpx;
}

.emoji-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.emoji-pick {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  border: 2rpx solid transparent;
}

.emoji-pick.on {
  border-color: #3b82f6;
  background: #e8f3ff;
}

.form-save {
  margin-top: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 24rpx;
  background: #3b82f6;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

/* 创建面板盖住面具面板 */
.create-panel {
  z-index: 100;
  top: 10%;
}

/* —— 登录门闸 —— */
.login-gate {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 300;
  background: linear-gradient(180deg, #ffffff 0%, #eef5ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.login-card {
  width: 100%;
  max-width: 640rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #3b82f6, #60a5fa);
  color: #fff;
  font-size: 52rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(59, 130, 246, 0.25);
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1d2129;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #86909c;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 40rpx;
}

.login-profile {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 40rpx;
}

.avatar-btn {
  width: 148rpx !important;
  height: 148rpx !important;
  min-width: 148rpx !important;
  max-width: 148rpx !important;
  min-height: 148rpx !important;
  max-height: 148rpx !important;
  padding: 0 !important;
  margin: 0 auto !important;
  border-radius: 50% !important;
  overflow: hidden;
  background: linear-gradient(145deg, #e8f5ec 0%, #f5faf7 100%) !important;
  border: 3rpx solid rgba(64, 145, 108, 0.35) !important;
  line-height: normal !important;
  display: flex !important;
  align-items: center;
  justify-content: center;
  box-sizing: border-box !important;
  box-shadow: 0 8rpx 24rpx rgba(64, 145, 108, 0.12);
}

.avatar-btn::after {
  border: none !important;
}

.avatar-btn-hover {
  opacity: 0.88;
}

.avatar-img {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  display: block;
}

.avatar-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.avatar-empty-icon {
  font-size: 36rpx;
  color: #40916c;
  line-height: 1;
  font-weight: 500;
}

.avatar-empty-text {
  font-size: 22rpx;
  color: #5b8a72;
  line-height: 1;
}

.avatar-ph {
  font-size: 24rpx;
  color: #86909c;
  line-height: 1;
}

.nick-wrap {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.nick-label {
  font-size: 24rpx;
  color: #5b8a72;
  padding-left: 8rpx;
  font-weight: 500;
}

.nick-input {
  width: 100%;
  height: 88rpx;
  background: #f4faf6;
  border-radius: 22rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #1e3a2a;
  border: 2rpx solid rgba(64, 145, 108, 0.18);
}

.login-form {
  width: 100%;
}

.login-btn {
  width: 100% !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  border-radius: 999rpx !important;
  background: linear-gradient(135deg, #52b788 0%, #40916c 55%, #2d6a4f 100%) !important;
  color: #fff !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  border: none !important;
  margin: 0 !important;
  padding: 0 !important;
  letter-spacing: 2rpx;
  box-shadow: 0 12rpx 28rpx rgba(64, 145, 108, 0.28);
}

.login-btn-sm {
  height: 72rpx !important;
  line-height: 72rpx !important;
  font-size: 28rpx !important;
  letter-spacing: 1rpx;
  box-shadow: 0 6rpx 16rpx rgba(64, 145, 108, 0.18) !important;
}

.login-btn-wx {
  margin-bottom: 8rpx !important;
}

.login-btn-secondary {
  background: #fff !important;
  color: #2d6a4f !important;
  border: 2rpx solid rgba(64, 145, 108, 0.35) !important;
  box-shadow: none !important;
}

.login-btn-secondary.login-btn-sm {
  box-shadow: none !important;
}

.login-btn::after {
  border: none !important;
}

.login-btn-hover {
  opacity: 0.92;
}

.login-or {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 28rpx 0 24rpx;
}

.login-or-line {
  flex: 1;
  height: 1rpx;
  background: rgba(64, 145, 108, 0.18);
}

.login-or-text {
  font-size: 22rpx;
  color: #8aa396;
  flex-shrink: 0;
}

.login-fields {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.code-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.code-input {
  flex: 1;
  min-width: 0;
}

.code-btn {
  flex-shrink: 0;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 22rpx;
  background: rgba(64, 145, 108, 0.12);
  color: #2d6a4f;
  font-size: 26rpx;
  font-weight: 600;
  white-space: nowrap;
}

.code-btn.disabled {
  opacity: 0.45;
  pointer-events: none;
}

.login-switch {
  margin-top: 22rpx;
  text-align: center;
  font-size: 26rpx;
  color: #40916c;
  font-weight: 500;
  padding: 8rpx;
}

.login-home {
  margin-top: 28rpx;
  font-size: 26rpx;
  color: #86909c;
}

/* —— 抽屉 —— */
.drawer-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
}

.drawer-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.drawer {
  position: fixed;
  left: 0; top: 0; bottom: 0;
  width: 78%;
  max-width: 560rpx;
  background: #fff;
  z-index: 210;
  transform: translateX(-105%);
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: 0 28rpx 28rpx;
}

.drawer.show { transform: translateX(0); }

.drawer-user {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 8rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  margin-bottom: 12rpx;
}

.drawer-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #3b82f6, #60a5fa);
  flex-shrink: 0;
}

.drawer-avatar.ph {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.drawer-name { font-size: 30rpx; font-weight: 600; color: #1d2129; }
.drawer-tip { margin-top: 4rpx; font-size: 22rpx; color: #86909c; }

.drawer-item {
  padding: 26rpx 12rpx;
  font-size: 28rpx;
  color: #1d2129;
  border-radius: 16rpx;
}

.drawer-item.danger { color: #f53f3f; }

.drawer-sec {
  margin-top: 16rpx;
  padding: 12rpx 12rpx 8rpx;
  font-size: 22rpx;
  color: #86909c;
}

.drawer-hist { flex: 1; height: 0; }
.drawer-empty { padding: 24rpx 12rpx; font-size: 24rpx; color: #c9cdd4; }

.drawer-hist-item { padding: 20rpx 12rpx; border-radius: 16rpx; }
.drawer-hist-title { font-size: 26rpx; color: #1d2129; font-weight: 500; }
.drawer-hist-preview {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #86909c;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.drawer-foot {
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  padding-top: 8rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.guest-tip {
  margin-top: 20rpx;
  margin-bottom: 8rpx;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #fff7e8;
  color: #d97706;
  font-size: 24rpx;
}

.drawer-item.primary {
  color: #40916c;
  font-weight: 600;
}

.login-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 220;
  background: linear-gradient(180deg, #ffffff 0%, #f3faf6 100%);
  border-radius: 36rpx 36rpx 0 0;
  padding: 20rpx 40rpx calc(36rpx + env(safe-area-inset-bottom));
  transform: translateY(110%);
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  box-sizing: border-box;
  box-shadow: 0 -12rpx 40rpx rgba(30, 58, 42, 0.08);
}

.login-sheet.show { transform: translateY(0); }

.login-handle {
  width: 64rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(30, 58, 42, 0.12);
  margin: 0 auto 28rpx;
}

.login-brand {
  text-align: center;
  font-size: 22rpx;
  letter-spacing: 0.28em;
  color: #40916c;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.login-sheet-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e3a2a;
  text-align: center;
}

.login-sheet-desc {
  margin-top: 12rpx;
  margin-bottom: 36rpx;
  font-size: 24rpx;
  color: #6b8f7a;
  text-align: center;
  line-height: 1.55;
}

.login-cancel {
  margin-top: 28rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8aa396;
  padding: 12rpx;
}

.login-mask {
  z-index: 215;
  background: rgba(15, 40, 28, 0.42);
}

.drawer-hist-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 8rpx 16rpx 12rpx;
  border-radius: 16rpx;
}

.drawer-hist-item.on {
  background: #f0f7ff;
}

.drawer-hist-main {
  flex: 1;
  min-width: 0;
}

.drawer-hist-del {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  font-size: 22rpx;
  color: #f53f3f;
  border-radius: 12rpx;
}

/* —— 平板 / 电脑宽屏适配 —— */
.page.is-wide {
  background: #e8eaed;
}

.page.is-wide .nav,
.page.is-wide .msgs,
.page.is-wide .composer,
.page.is-wide .img-bar {
  width: 100%;
  max-width: 840px;
  margin-left: auto;
  margin-right: auto;
  box-sizing: border-box;
}

.page.is-wide .nav,
.page.is-wide .composer,
.page.is-wide .img-bar {
  background: #fff;
}

.page.is-wide .msgs {
  background: #f7f8fa;
}

.page.is-wide .skill-grid {
  grid-template-columns: repeat(6, 1fr);
  max-width: 100%;
}

.page.is-wide .welcome {
  padding-top: 48rpx;
  max-width: 720px;
  margin: 0 auto;
}

.page.is-wide .bubble-wrap {
  max-width: 68%;
}

.page.is-wide .bubble-img {
  width: 560rpx;
}

.page.is-wide .drawer {
  width: 360px;
  max-width: 42%;
}

.page.is-pc .drawer {
  width: 320px;
  max-width: 320px;
}

/* 底部面板在宽屏下居中，对齐主内容列 */
.page.is-wide .sheet,
.page.is-wide .panel,
.page.is-wide .create-panel,
.page.is-wide .login-sheet {
  left: 50%;
  right: auto;
  width: 100%;
  max-width: 840px;
  margin: 0;
  transform: translate(-50%, 110%);
}

.page.is-wide .sheet.show,
.page.is-wide .panel.show,
.page.is-wide .create-panel.show,
.page.is-wide .login-sheet.show {
  transform: translate(-50%, 0);
}

.page.is-wide .login-sheet {
  max-width: 480px;
}

.page.is-wide .panel-grid {
  grid-template-columns: repeat(3, 1fr);
}

.page.is-wide .sheet-grid {
  grid-template-columns: repeat(4, 1fr);
  max-width: 640px;
  margin: 0 auto;
}

.page.is-wide .login-sheet,
.page.is-wide .login-card {
  max-width: 480px;
  margin: 0 auto;
}

.page.is-wide .login-gate {
  align-items: center;
}

.page.is-pc .nav-inner {
  height: 96rpx;
}

.page.is-pc .composer-box {
  padding: 12rpx 14rpx;
}

.page.is-pc .input {
  height: 72rpx;
  font-size: 30rpx;
}

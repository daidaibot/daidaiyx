<view class="page">
  <view class="nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-row">
      <view class="back" bindtap="goBack">←</view>
      <view class="nav-center">
        <view class="nav-brand">呆呆 AI</view>
        <view class="nav-sub">DAIDAI NETWORK</view>
      </view>
      <view class="clear" bindtap="onClear">清空</view>
    </view>
  </view>

  <scroll-view
    class="feed"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    scroll-into-view="{{scrollInto}}"
    scroll-with-animation
  >
    <view class="feed-inner">
      <view wx:if="{{!started}}" class="empty">
        <view class="empty-title">今天想解决什么？</view>
        <view class="empty-desc">流式对话 · 多轮上下文 · 呆呆网络定制助手</view>
        <view class="chips">
          <view
            class="chip"
            wx:for="{{suggestions}}"
            wx:key="*this"
            data-text="{{item}}"
            bindtap="onChip"
          >{{item}}</view>
        </view>
      </view>

      <block wx:for="{{messages}}" wx:key="id">
        <view id="m{{item.id}}" class="row {{item.role}}">
          <view class="meta" wx:if="{{item.role === 'assistant'}}">呆呆</view>
          <view class="bubble {{item.role}} {{item.streaming ? 'streaming' : ''}}">
            <text selectable>{{item.content || (item.streaming ? '…' : '')}}</text>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>

  <view class="dock">
    <view class="composer">
      <input
        class="field"
        value="{{input}}"
        placeholder="发给呆呆 AI…"
        placeholder-class="ph"
        confirm-type="send"
        adjust-position
        hold-keyboard
        disabled="{{loading}}"
        bindinput="onInput"
        bindconfirm="onSend"
      />
      <view
        class="send {{!input || loading ? 'disabled' : ''}}"
        bindtap="onSend"
      >{{loading ? '…' : '发送'}}</view>
    </view>
  </view>
</view>

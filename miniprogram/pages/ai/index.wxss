.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #0b1c2c, #071018);
  box-sizing: border-box;
}

.list {
  flex: 1;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
}

.bubble {
  max-width: 82%;
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-word;
}

.bubble.user {
  margin-left: auto;
  background: #f0c75e;
  color: #1a1408;
}

.bubble.assistant {
  margin-right: auto;
  background: rgba(30, 58, 84, 0.95);
  color: #eef5fb;
  border: 1rpx solid rgba(155, 179, 199, 0.25);
}

.composer {
  display: flex;
  gap: 16rpx;
  align-items: center;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(8, 18, 28, 0.96);
}

.input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #14324a;
  color: #eef5fb;
  font-size: 28rpx;
}

.send {
  margin: 0 !important;
  background: #f0c75e !important;
  color: #1a1408 !important;
  border-radius: 999rpx !important;
  font-weight: 700;
}

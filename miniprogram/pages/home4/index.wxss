.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f9fafc;
}

.nav {
  background: #fff;
  border-bottom: 1rpx solid #eef0f5;
  flex-shrink: 0;
}

.nav-row {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 8rpx;
}

.back {
  width: 72rpx;
  height: 72rpx;
  line-height: 68rpx;
  text-align: center;
  font-size: 52rpx;
  color: #333;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.spacer {
  width: 72rpx;
}

.body {
  flex: 1;
  height: 0;
}

.home-header {
  margin: 30rpx 30rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #666;
}

.grid-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  width: calc(100% - 60rpx);
  margin: 0 30rpx;
}

.grid-item {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  border-radius: 20rpx;
  background-color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.grid-item-content {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx;
}

.tool-icon-container {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #f0f4ff 0%, #e6eeff 100%);
  margin-bottom: 20rpx;
}

.tool-icon {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
}

.tool-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
  text-align: center;
  width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tool-description {
  font-size: 20rpx;
  color: #666;
  text-align: center;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  width: 100%;
  height: 52rpx;
}

.footer {
  margin-top: 40rpx;
  padding: 30rpx 0 60rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}

.link {
  margin-top: 24rpx;
  color: #5b6cff;
  font-size: 28rpx;
  font-weight: 600;
}

.link.dim {
  color: #39b54a;
  font-weight: 500;
}

.scrollPage {
  height: 100vh;
  box-sizing: border-box;
}

.UCenter-bg {
  background-image: linear-gradient(135deg, #39b54a, #8dc63f 45%, #1cbbb4);
  background-size: cover;
  height: 480rpx;
  display: flex;
  justify-content: center;
  padding-top: 40rpx;
  overflow: hidden;
  position: relative;
  flex-direction: column;
  align-items: center;
  color: #fff;
  font-weight: 300;
  text-shadow: 0 0 3px rgba(0, 0, 0, 0.25);
}

.UCenter-bg text {
  opacity: 0.9;
}

.UCenter-bg .brand-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  margin-bottom: 16rpx;
  color: #39b54a;
  font-size: 64rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  text-shadow: none;
}

.UCenter-bg .gif-wave {
  position: absolute;
  width: 100%;
  bottom: 0;
  left: 0;
  height: 80rpx;
  background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.35));
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #ffffff 0%, #f0faf4 55%, #e8f5ec 100%);
  color: #1e3a2a;
  box-sizing: border-box;
}

.nav {
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.92);
  border-bottom: 1rpx solid rgba(82, 183, 136, 0.2);
}

.nav-inner {
  height: 88rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
}

.back {
  width: 72rpx;
  height: 72rpx;
  line-height: 68rpx;
  text-align: center;
  font-size: 52rpx;
  color: #40916c;
  font-weight: 300;
}

.nav-center {
  flex: 1;
  text-align: center;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e3a2a;
}

.nav-sub {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: #52b788;
  letter-spacing: 0.08em;
}

.nav-spacer {
  width: 72rpx;
}

.body {
  flex: 1;
  height: 0;
}

.hero {
  padding: 48rpx 40rpx 24rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1e3a2a;
}

.hero-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(30, 58, 42, 0.65);
  line-height: 1.5;
}

.sec {
  padding: 28rpx 32rpx 8rpx;
}

.sec-label {
  font-size: 24rpx;
  color: #52b788;
  margin-bottom: 20rpx;
  letter-spacing: 0.08em;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.list-item {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 28rpx 24rpx;
  background: #fff;
  border: 1rpx solid rgba(82, 183, 136, 0.22);
  border-radius: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(64, 145, 108, 0.05);
}

.list-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.list-main {
  flex: 1;
  min-width: 0;
}

.list-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e3a2a;
}

.list-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: rgba(30, 58, 42, 0.65);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.list-arrow {
  font-size: 40rpx;
  color: rgba(64, 145, 108, 0.45);
  line-height: 1;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.grid-item {
  background: #fff;
  border: 1rpx solid rgba(82, 183, 136, 0.22);
  border-radius: 28rpx;
  padding: 28rpx 22rpx 32rpx;
  box-shadow: 0 8rpx 28rpx rgba(64, 145, 108, 0.05);
  box-sizing: border-box;
}

.grid-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  margin-bottom: 16rpx;
  background: #f0faf4;
}

.grid-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e3a2a;
  margin-bottom: 8rpx;
}

.grid-desc {
  font-size: 22rpx;
  color: rgba(30, 58, 42, 0.65);
  line-height: 1.4;
}

.foot {
  text-align: center;
  padding: 48rpx 24rpx 16rpx;
  font-size: 22rpx;
  color: rgba(30, 58, 42, 0.45);
}

.safe {
  height: calc(24rpx + env(safe-area-inset-bottom));
}

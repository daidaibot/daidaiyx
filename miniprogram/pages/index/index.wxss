.root {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffffff 0%, #f0faf4 60%, #e8f5ec 100%);
  color: #1e3a2a;
}

/* —— Splash —— */
.splash {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(165deg, #ffffff 0%, #eef8f1 50%, #dceee3 100%);
  transition: opacity 0.75s ease, visibility 0.75s;
}

.splash.is-leaving .splash-scene {
  opacity: 0;
  transform: scale(1.06);
  filter: blur(6px);
  transition: opacity 0.7s ease, transform 0.7s ease, filter 0.7s ease;
}

.splash.is-hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.splash-scene {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 64rpx;
}

.splash-ring {
  position: absolute;
  width: 280rpx;
  height: 280rpx;
  top: 50%;
  left: 50%;
  margin: -140rpx 0 0 -140rpx;
  border: 2rpx solid rgba(64, 145, 108, 0.35);
  border-radius: 50%;
  animation: ringPulse 2.4s ease-out forwards;
}

.splash-ring--delay {
  animation-delay: 0.35s;
  border-color: rgba(82, 183, 136, 0.2);
}

@keyframes ringPulse {
  0% {
    transform: scale(0.4);
    opacity: 0;
  }
  25% {
    opacity: 1;
  }
  100% {
    transform: scale(2.6);
    opacity: 0;
  }
}

.splash-label {
  font-size: 22rpx;
  letter-spacing: 0.35em;
  color: #52b788;
  opacity: 1;
}

.splash-name {
  margin-top: 32rpx;
  opacity: 1;
  transform: none;
  filter: none;
}

.splash-line {
  width: 240rpx;
  height: 2rpx;
  margin-top: 56rpx;
  background: linear-gradient(90deg, transparent, #52b788, transparent);
  opacity: 1;
}

.splash-skip {
  position: absolute;
  bottom: calc(80rpx + env(safe-area-inset-bottom));
  font-size: 22rpx;
  letter-spacing: 0.15em;
  color: rgba(30, 58, 42, 0.65);
  opacity: 0.9;
}

/* —— Page —— */
.page-wrap {
  min-height: 100vh;
  opacity: 1;
  transition: opacity 0.6s ease;
}

.page-wrap.ready {
  opacity: 1;
}

.nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.92);
  border-bottom: 1rpx solid rgba(82, 183, 136, 0.2);
}

.nav-inner {
  height: 88rpx;
  padding: 0 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.nav-logo {
  display: flex;
  align-items: center;
}

.nav-links {
  display: flex;
  gap: 56rpx;
}

.nav-link {
  font-size: 28rpx;
  color: rgba(30, 58, 42, 0.65);
}

.brand-logo {
  display: block;
  width: auto;
  flex-shrink: 0;
}

.brand-logo--nav {
  height: 64rpx;
}

.brand-logo--splash {
  height: 120rpx;
}

.brand-logo--hero {
  height: 96rpx;
  margin: 0 auto;
}

.brand-logo--footer {
  display: inline-block;
  height: 28rpx;
  vertical-align: middle;
  margin: 0 6rpx;
  transform: translateY(-2rpx);
}

.scroll {
  height: 100vh;
  box-sizing: border-box;
}

/* —— Hero —— */
.hero {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding-left: 48rpx;
  padding-right: 48rpx;
  padding-bottom: 96rpx;
}

.hero-signature {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  line-height: 1;
}

.hero-tagline {
  margin: 0;
  font-family: Georgia, 'Times New Roman', 'Songti SC', serif;
  font-size: 36rpx;
  font-style: italic;
  font-weight: 400;
  letter-spacing: 0.06em;
  line-height: 1.4;
  color: rgba(30, 58, 42, 0.65);
}

.hero-actions {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24rpx;
  margin-top: 56rpx;
}

.hero-ai {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
}

.btn-ai {
  min-width: auto;
  padding: 14rpx 36rpx;
  font-size: 24rpx;
  background: linear-gradient(135deg, #2d6a4f 0%, #40916c 55%, #52b788 100%);
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(64, 145, 108, 0.2);
  transition: transform 0.22s ease, box-shadow 0.22s ease, opacity 0.22s ease;
}

.btn-ai.press {
  transform: scale(0.96);
  opacity: 0.92;
  box-shadow: 0 4rpx 12rpx rgba(64, 145, 108, 0.16);
}

.hero-in {
  opacity: 0;
  animation: heroIn 0.65s ease-out forwards;
}

@keyframes heroIn {
  from {
    opacity: 0;
    transform: translate3d(0, 18px, 0);
  }
  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

.btn {
  display: inline-block;
  padding: 24rpx 52rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 1.2;
  text-align: center;
  box-sizing: border-box;
}

.btn-primary {
  background: #40916c;
  color: #fff;
}

.btn-ghost {
  background: #fff;
  color: #40916c;
  border: 1rpx solid rgba(82, 183, 136, 0.22);
}

.hero-scroll-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 72rpx;
}

.hero-scroll-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  color: rgba(30, 58, 42, 0.65);
  opacity: 0;
  animation: scrollHintFade 0.7s ease 0.55s forwards, scrollHintBob 2.6s ease-in-out 1.2s infinite;
}

@keyframes scrollHintFade {
  to {
    opacity: 1;
  }
}

@keyframes scrollHintBob {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(7px);
  }
}

.hero-scroll-text {
  font-size: 22rpx;
  letter-spacing: 0.16em;
}

.hero-scroll-arrow {
  font-size: 28rpx;
  opacity: 0.75;
}

/* —— Sections —— */
.section {
  padding: 128rpx 48rpx 64rpx;
  box-sizing: border-box;
  max-width: 1000px;
  margin: 0 auto;
}

.section-label {
  font-size: 24rpx;
  color: #52b788;
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1e3a2a;
  margin-bottom: 64rpx;
}

.about-grid,
.contact-grid {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.glass-card {
  background: #fff;
  border: 1rpx solid rgba(82, 183, 136, 0.22);
  border-radius: 32rpx;
  padding: 56rpx 48rpx;
  box-shadow: 0 8rpx 40rpx rgba(64, 145, 108, 0.06);
  box-sizing: border-box;
}

.card-icon {
  color: #52b788;
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1e3a2a;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 28rpx;
  color: rgba(30, 58, 42, 0.65);
  line-height: 1.6;
}

.contact-subtitle {
  color: rgba(30, 58, 42, 0.65);
  margin: -40rpx 0 48rpx;
  font-size: 28rpx;
}

.contact-card {
  text-align: center;
  padding: 56rpx 40rpx;
}

.contact-icon {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 24rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.contact-icon.wechat {
  background: rgba(7, 193, 96, 0.12);
}

.contact-icon.qq {
  background: rgba(18, 183, 245, 0.12);
}

.contact-icon-txt {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.wechat-txt {
  color: #07c160;
}

.qq-txt {
  color: #12b7f5;
}

.contact-h3 {
  font-size: 28rpx;
  color: rgba(30, 58, 42, 0.65);
  margin-bottom: 12rpx;
}

.contact-value {
  font-size: 38rpx;
  font-weight: 600;
  color: #1e3a2a;
  margin-bottom: 28rpx;
  word-break: break-all;
}

.copy-btn {
  display: inline-block;
  padding: 12rpx 36rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(82, 183, 136, 0.22);
  background: #e8f5ec;
  color: #40916c;
  font-size: 26rpx;
}

.ai-entry {
  display: none;
}

.footer {
  text-align: center;
  padding: 64rpx 32rpx 32rpx;
  color: rgba(30, 58, 42, 0.65);
  font-size: 26rpx;
  border-top: 1rpx solid rgba(82, 183, 136, 0.2);
  background: rgba(255, 255, 255, 0.7);
  margin-top: 40rpx;
}

.safe {
  height: calc(24rpx + env(safe-area-inset-bottom));
}

.toast {
  position: fixed;
  bottom: 48rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 20rpx 40rpx;
  background: #40916c;
  color: #fff;
  border-radius: 999rpx;
  font-size: 26rpx;
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease;
  white-space: nowrap;
}

.toast.show {
  opacity: 1;
  visibility: visible;
}

/* —— AI 打开过渡 —— */
.ai-transit {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10000;
  background: rgba(247, 248, 250, 0);
  pointer-events: none;
  opacity: 0;
  transition: background 0.42s ease, opacity 0.28s ease;
}

.ai-transit.show {
  pointer-events: auto;
  opacity: 1;
  background: rgba(247, 248, 250, 0.96);
}

.ai-transit-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 18%;
  background: #f7f8fa;
  border-radius: 40rpx 40rpx 0 0;
  box-shadow: 0 -16rpx 48rpx rgba(15, 23, 42, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: translate3d(0, 110%, 0);
  transition: transform 0.48s cubic-bezier(0.22, 1, 0.36, 1);
}

.ai-transit.show .ai-transit-sheet {
  transform: translate3d(0, 0, 0);
}

.ai-transit-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #3b82f6, #60a5fa);
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(59, 130, 246, 0.25);
  opacity: 0;
  transform: scale(0.86);
  transition: opacity 0.35s ease 0.12s, transform 0.35s cubic-bezier(0.22, 1, 0.36, 1) 0.12s;
}

.ai-transit.show .ai-transit-avatar {
  opacity: 1;
  transform: scale(1);
}

.ai-transit-text {
  font-size: 28rpx;
  color: #86909c;
  letter-spacing: 0.06em;
  opacity: 0;
  transform: translateY(12rpx);
  transition: opacity 0.35s ease 0.18s, transform 0.35s ease 0.18s;
}

.ai-transit.show .ai-transit-text {
  opacity: 1;
  transform: translateY(0);
}

/* —— 平板 / 电脑宽屏 —— */
.root.is-wide {
  background: linear-gradient(180deg, #f7fcf9 0%, #eef8f1 45%, #e4f2ea 100%);
}

.root.is-wide .nav-inner {
  max-width: 960px;
  margin: 0 auto;
  width: 100%;
}

.root.is-wide .hero {
  max-width: 720px;
  margin: 0 auto;
}

.root.is-wide .brand-logo--hero {
  height: 112rpx;
}

.root.is-wide .hero-tagline {
  font-size: 40rpx;
}

.root.is-wide .section {
  max-width: 920px;
}

.root.is-wide .about-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.root.is-wide .contact-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.root.is-wide .ai-transit-sheet {
  left: 50%;
  right: auto;
  width: 100%;
  max-width: 840px;
  transform: translate3d(-50%, 110%, 0);
}

.root.is-wide .ai-transit.show .ai-transit-sheet {
  transform: translate3d(-50%, 0, 0);
}

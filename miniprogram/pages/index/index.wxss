.stage {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(1000rpx 600rpx at 8% -10%, rgba(44, 108, 148, 0.5) 0%, transparent 55%),
    linear-gradient(165deg, #081722, #040b12 60%);
}

.glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(36rpx);
}
.glow.a {
  width: 380rpx;
  height: 380rpx;
  left: -40rpx;
  top: 240rpx;
  background: rgba(64, 148, 190, 0.28);
}
.glow.b {
  width: 320rpx;
  height: 320rpx;
  right: -40rpx;
  bottom: 200rpx;
  background: rgba(240, 199, 94, 0.16);
}

.box {
  position: relative;
  z-index: 2;
  padding: 140rpx 48rpx 0;
  opacity: 0;
  transform: translateY(24rpx);
  transition: all 0.65s ease;
}
.box.in {
  opacity: 1;
  transform: none;
}

.brand {
  font-size: 68rpx;
  font-weight: 800;
  letter-spacing: 0.2em;
  color: #f0c75e;
}

.line {
  margin-top: 40rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #f4f8fc;
}

.desc {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: rgba(201, 220, 235, 0.75);
  line-height: 1.6;
}

.btn {
  margin-top: 80rpx;
  display: inline-block;
  padding: 28rpx 48rpx;
  border-radius: 999rpx;
  background: linear-gradient(120deg, #f0c75e, #d9a83a);
  color: #1a1408;
  font-size: 30rpx;
  font-weight: 700;
}

.foot {
  position: absolute;
  left: 48rpx;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  font-size: 18rpx;
  letter-spacing: 0.28em;
  color: rgba(155, 179, 199, 0.45);
}

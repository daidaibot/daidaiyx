.root {
  min-height: 100vh;
  position: relative;
}

/* —— Splash（dai520 开场） —— */
.splash {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(165deg, #ffffff 0%, #eef8f1 50%, #dceee3 100%);
  transition: opacity 0.75s ease, visibility 0.75s;
}

.splash.is-leaving .splash-scene {
  opacity: 0;
  transform: scale(1.06);
  filter: blur(6px);
  transition: all 0.7s ease;
}

.splash.is-hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.splash-scene {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 40rpx;
}

.splash-ring {
  position: absolute;
  width: 280rpx;
  height: 280rpx;
  top: 50%;
  left: 50%;
  margin: -140rpx 0 0 -140rpx;
  border: 2rpx solid rgba(64, 145, 108, 0.35);
  border-radius: 50%;
  animation: ringPulse 2.4s ease-out infinite;
}

.splash-ring.delay {
  animation-delay: 0.35s;
  border-color: rgba(82, 183, 136, 0.2);
}

@keyframes ringPulse {
  0% { transform: scale(0.4); opacity: 0; }
  25% { opacity: 1; }
  100% { transform: scale(2.4); opacity: 0; }
}

.splash-label {
  font-size: 22rpx;
  letter-spacing: 0.35em;
  color: #52b788;
  margin-bottom: 24rpx;
}

.splash-brand {
  font-size: 88rpx;
  font-weight: 300;
  color: #40916c;
  letter-spacing: 0.2em;
  font-family: "Songti SC", "STSong", "SimSun", Georgia, serif;
}

.splash-line {
  width: 160rpx;
  height: 2rpx;
  margin-top: 40rpx;
  background: linear-gradient(90deg, transparent, #52b788, transparent);
}

.splash-skip {
  position: absolute;
  bottom: calc(80rpx + env(safe-area-inset-bottom));
  font-size: 22rpx;
  letter-spacing: 0.15em;
  color: rgba(30, 58, 42, 0.65);
}

/* —— Page —— */
.page {
  min-height: 100vh;
  opacity: 0;
  transition: opacity 0.6s ease;
}

.page.show {
  opacity: 1;
}

.nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 50;
  background: rgba(255, 255, 255, 0.92);
  border-bottom: 1rpx solid rgba(82, 183, 136, 0.2);
}

.nav-inner {
  height: 88rpx;
  padding: 0 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-logo {
  color: #40916c;
  font-size: 34rpx;
  letter-spacing: 0.18em;
  font-family: "Songti SC", "STSong", "SimSun", Georgia, serif;
}

.nav-links {
  display: flex;
  gap: 36rpx;
}

.nav-link {
  font-size: 26rpx;
  color: rgba(30, 58, 42, 0.65);
}

.scroll {
  height: 100vh;
}

.hero {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 40rpx 40rpx 80rpx;
}

.hero-brand {
  font-size: 72rpx;
  color: #40916c;
  letter-spacing: 0.16em;
  font-weight: 300;
  font-family: "Songti SC", "STSong", "SimSun", Georgia, serif;
  line-height: 1.2;
  opacity: 0;
}

.hero-tagline {
  margin-top: 24rpx;
  font-size: 36rpx;
  font-style: italic;
  letter-spacing: 0.08em;
  color: rgba(30, 58, 42, 0.65);
  font-family: Georgia, "Times New Roman", "Songti SC", serif;
  opacity: 0;
}

.hero-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 48rpx;
  opacity: 0;
}

.btn {
  padding: 22rpx 44rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 1.2;
}

.btn-primary {
  background: #40916c;
  color: #fff;
}

.btn-ghost {
  background: #fff;
  color: #40916c;
  border: 1rpx solid rgba(82, 183, 136, 0.22);
}

.scroll-hint {
  margin-top: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  opacity: 0;
  animation: bob 2.6s ease-in-out 1.2s infinite;
}

.scroll-text {
  font-size: 22rpx;
  letter-spacing: 0.16em;
  color: rgba(30, 58, 42, 0.65);
}

.scroll-arrow {
  font-size: 28rpx;
  color: rgba(30, 58, 42, 0.55);
}

@keyframes bob {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(10rpx); }
}

.hero-brand.in,
.hero-tagline.in,
.hero-actions.in,
.scroll-hint.in {
  animation: heroIn 0.65s ease-out forwards;
}

@keyframes heroIn {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.section {
  padding: 80rpx 40rpx 40rpx;
  max-width: 1000rpx;
  margin: 0 auto;
  box-sizing: border-box;
}

.section-label {
  font-size: 24rpx;
  color: #52b788;
  margin-bottom: 10rpx;
}

.section-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1e3a2a;
  margin-bottom: 40rpx;
}

.about-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.glass-card {
  background: #fff;
  border: 1rpx solid rgba(82, 183, 136, 0.22);
  border-radius: 32rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(64, 145, 108, 0.06);
}

.card-icon {
  color: #52b788;
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e3a2a;
  margin-bottom: 10rpx;
}

.card-desc {
  font-size: 26rpx;
  color: rgba(30, 58, 42, 0.65);
  line-height: 1.6;
}

.contact-sub {
  margin-top: -24rpx;
  margin-bottom: 32rpx;
  font-size: 28rpx;
  color: rgba(30, 58, 42, 0.65);
}

.start-card {
  text-align: center;
}

.start-btn {
  display: inline-block;
  margin-top: 28rpx;
}

.footer {
  text-align: center;
  padding: 48rpx 24rpx 16rpx;
  color: rgba(30, 58, 42, 0.65);
  font-size: 22rpx;
  border-top: 1rpx solid rgba(82, 183, 136, 0.2);
  margin-top: 40rpx;
}

.safe {
  height: calc(24rpx + env(safe-area-inset-bottom));
}

.stage {
  min-height: 100vh;
  padding: 24rpx 36rpx 80rpx;
  box-sizing: border-box;
  background: #f4f6fb;
  color: #152033;
}

.pad { width: 100%; }

.title {
  margin-top: 48rpx;
  font-size: 48rpx;
  font-weight: 800;
}

.sub {
  margin-top: 12rpx;
  margin-bottom: 40rpx;
  font-size: 26rpx;
  color: #738094;
}

.card {
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  color: #fff;
  box-shadow: 0 16rpx 40rpx rgba(21, 32, 51, 0.12);
}

.card.a {
  background: linear-gradient(135deg, #39b54a, #8dc63f 55%, #1cbbb4);
}

.card.b {
  background: linear-gradient(135deg, #5b6cff, #8b5cf6);
}

.badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  font-size: 20rpx;
  margin-bottom: 16rpx;
}

.name {
  font-size: 40rpx;
  font-weight: 700;
}

.desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.chat {
  margin-top: 48rpx;
  text-align: center;
  color: #5b6cff;
  font-size: 28rpx;
  font-weight: 600;
}

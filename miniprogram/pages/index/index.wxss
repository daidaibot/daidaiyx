.root {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffffff 0%, #f0faf4 60%, #e8f5ec 100%);
}

.splash {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(165deg, #ffffff 0%, #eef8f1 50%, #dceee3 100%);
  transition: opacity 0.45s ease;
}

.splash.leave {
  opacity: 0;
  pointer-events: none;
}

.splash-label {
  font-size: 24rpx;
  letter-spacing: 0.35em;
  color: #52b788;
  margin-bottom: 28rpx;
}

.splash-brand {
  font-size: 96rpx;
  font-weight: 400;
  color: #40916c;
  letter-spacing: 0.2em;
}

.splash-line {
  width: 160rpx;
  height: 2rpx;
  margin-top: 40rpx;
  background: linear-gradient(90deg, transparent, #52b788, transparent);
}

.splash-skip {
  position: absolute;
  bottom: calc(80rpx + env(safe-area-inset-bottom));
  font-size: 24rpx;
  letter-spacing: 0.12em;
  color: rgba(30, 58, 42, 0.65);
}

.page {
  min-height: 100vh;
}

.nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 50;
  background: rgba(255, 255, 255, 0.94);
  border-bottom: 1rpx solid rgba(82, 183, 136, 0.2);
}

.nav-inner {
  height: 88rpx;
  padding: 0 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.nav-logo {
  color: #40916c;
  font-size: 34rpx;
  letter-spacing: 0.18em;
}

.nav-links {
  display: flex;
  gap: 36rpx;
}

.nav-link {
  font-size: 26rpx;
  color: rgba(30, 58, 42, 0.65);
}

.scroll {
  height: 100vh;
  box-sizing: border-box;
}

.hero {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding-left: 40rpx;
  padding-right: 40rpx;
  padding-bottom: 80rpx;
}

.hero-brand {
  font-size: 68rpx;
  color: #40916c;
  letter-spacing: 0.14em;
  font-weight: 400;
  line-height: 1.25;
}

.hero-tagline {
  margin-top: 24rpx;
  font-size: 34rpx;
  font-style: italic;
  letter-spacing: 0.06em;
  color: rgba(30, 58, 42, 0.65);
}

.hero-actions {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  margin-top: 48rpx;
}

.btn {
  padding: 22rpx 44rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 1.2;
  text-align: center;
}

.btn-primary {
  background: #40916c;
  color: #fff;
}

.btn-ghost {
  background: #fff;
  color: #40916c;
  border: 1rpx solid rgba(82, 183, 136, 0.25);
}

.scroll-hint {
  margin-top: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.scroll-text {
  font-size: 22rpx;
  letter-spacing: 0.14em;
  color: rgba(30, 58, 42, 0.65);
}

.scroll-arrow {
  font-size: 28rpx;
  color: rgba(30, 58, 42, 0.5);
}

.section {
  padding: 80rpx 40rpx 40rpx;
  box-sizing: border-box;
}

.section-label {
  font-size: 24rpx;
  color: #52b788;
  margin-bottom: 10rpx;
}

.section-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1e3a2a;
  margin-bottom: 40rpx;
}

.about-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.glass-card {
  background: #fff;
  border: 1rpx solid rgba(82, 183, 136, 0.22);
  border-radius: 32rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(64, 145, 108, 0.06);
}

.card-icon {
  color: #52b788;
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e3a2a;
  margin-bottom: 10rpx;
}

.card-desc {
  font-size: 26rpx;
  color: rgba(30, 58, 42, 0.65);
  line-height: 1.6;
}

.contact-sub {
  margin-top: -24rpx;
  margin-bottom: 32rpx;
  font-size: 28rpx;
  color: rgba(30, 58, 42, 0.65);
}

.start-card {
  text-align: center;
}

.start-btn {
  display: inline-block;
  margin-top: 28rpx;
}

.footer {
  text-align: center;
  padding: 48rpx 24rpx 16rpx;
  color: rgba(30, 58, 42, 0.65);
  font-size: 22rpx;
  border-top: 1rpx solid rgba(82, 183, 136, 0.2);
  margin-top: 40rpx;
}

.safe {
  height: calc(24rpx + env(safe-area-inset-bottom));
}

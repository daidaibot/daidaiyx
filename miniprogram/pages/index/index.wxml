<view class="stage">
  <view class="glow a"></view>
  <view class="glow b"></view>
  <view class="pad" style="height: {{statusBarHeight}}px;"></view>

  <view class="box {{ready ? 'in' : ''}}">
    <view class="brand">呆呆网络</view>
    <view class="line">高级 · 简约</view>
    <view class="desc">对话界面使用开源 chatgpt-web，部署后即可进入。</view>
    <view class="btn" bindtap="enterChat">进入呆呆 AI</view>
  </view>

  <view class="foot">CHATGPT-WEB</view>
</view>

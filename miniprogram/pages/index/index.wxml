<!-- 呆呆网络 · 风格参考 dai520.cn -->
<view class="root">
  <!-- 开场：淡绿欢迎层，可点可自动消失 -->
  <view
    wx:if="{{showSplash}}"
    class="splash {{splashLeaving ? 'leave' : ''}}"
    bindtap="enterSite"
  >
    <view class="splash-label">欢迎来访</view>
    <view class="splash-brand">呆呆</view>
    <view class="splash-line"></view>
    <view class="splash-skip">点击任意处进入</view>
  </view>

  <view class="page">
    <view class="nav" style="padding-top: {{statusBarHeight}}px;">
      <view class="nav-inner">
        <view class="nav-logo">呆呆</view>
        <view class="nav-links">
          <text class="nav-link" data-id="about" bindtap="scrollTo">关于</text>
          <text class="nav-link" bindtap="goChat">开始</text>
        </view>
      </view>
    </view>

    <scroll-view
      class="scroll"
      scroll-y
      scroll-into-view="{{scrollInto}}"
      scroll-with-animation
    >
      <view class="hero" id="hero" style="padding-top: {{heroPadTop}}px;">
        <view class="hero-brand">呆呆网络</view>
        <view class="hero-tagline">Happy every day</view>
        <view class="hero-actions">
          <view class="btn btn-primary" bindtap="goChat">进入呆呆 AI</view>
          <view class="btn btn-ghost" data-id="about" bindtap="scrollTo">了解更多</view>
        </view>
        <view class="scroll-hint" data-id="about" bindtap="scrollTo">
          <text class="scroll-text">下滑了解更多</text>
          <text class="scroll-arrow">↓</text>
        </view>
      </view>

      <view class="section" id="about">
        <view class="section-label">关于</view>
        <view class="section-title">关于呆呆</view>
        <view class="about-grid">
          <view class="glass-card" wx:for="{{cards}}" wx:key="title">
            <view class="card-icon">{{item.icon}}</view>
            <view class="card-title">{{item.title}}</view>
            <view class="card-desc">{{item.desc}}</view>
          </view>
        </view>
      </view>

      <view class="section" id="start">
        <view class="section-label">开始</view>
        <view class="section-title">联系与体验</view>
        <view class="contact-sub">期待与你一起玩转 AI · 点下面进入对话</view>
        <view class="glass-card start-card">
          <view class="card-title">呆呆 AI</view>
          <view class="card-desc">豆包风对话 · 马上开聊</view>
          <view class="btn btn-primary start-btn" bindtap="goChat">立即进入</view>
        </view>
      </view>

      <view class="footer">© {{year}} 呆呆网络 · Crafted with passion.</view>
      <view class="safe"></view>
    </scroll-view>
  </view>
</view>
